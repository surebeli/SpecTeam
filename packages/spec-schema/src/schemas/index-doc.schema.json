{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specteam.dev/schema/index-doc.schema.json",
  "title": "SpecTeam INDEX",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "envelope": {
      "allOf": [
        {
          "$ref": "https://specteam.dev/schema/envelope.schema.json"
        },
        {
          "type": "object",
          "properties": {
            "generator": {
              "const": "parse"
            },
            "generatedAt": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": ["generator", "generatedAt"]
        }
      ]
    },
    "northStar": {
      "type": "string",
      "minLength": 1
    },
    "northStarSource": {
      "type": "string",
      "minLength": 1
    },
    "decisionLog": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "divergences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "open": {
          "type": "integer",
          "minimum": 0
        },
        "proposed": {
          "type": "integer",
          "minimum": 0
        },
        "resolved": {
          "type": "integer",
          "minimum": 0
        },
        "fullyClosed": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["open", "proposed", "resolved", "notes"]
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "documentTree": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "collaborator": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "documents": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "summary": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": ["path", "summary"]
            }
          }
        },
        "required": ["collaborator", "documents"]
      }
    }
  },
  "required": [
    "envelope",
    "northStar",
    "decisionLog",
    "divergences",
    "signals",
    "documentTree"
  ]
}