{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specteam.dev/schema/action-item.schema.json",
  "title": "SpecTeam Action Item",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "owner": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "targetFile": {
      "type": "string",
      "pattern": "^\\./.+"
    },
    "completionState": {
      "type": "string",
      "enum": ["pending", "complete", "no-change-needed"]
    },
    "requiredChanges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptanceCriterion": {
      "type": "string",
      "minLength": 1
    },
    "background": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["owner", "targetFile", "completionState"],
  "allOf": [
    {
      "if": {
        "properties": {
          "completionState": {
            "enum": ["pending", "complete"]
          }
        },
        "required": ["completionState"]
      },
      "then": {
        "required": ["requiredChanges", "acceptanceCriterion", "background", "decision"]
      }
    }
  ]
}