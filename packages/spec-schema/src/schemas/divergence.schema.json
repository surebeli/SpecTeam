{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specteam.dev/schema/divergence.schema.json",
  "title": "SpecTeam Divergences",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "envelope": {
      "$ref": "https://specteam.dev/schema/envelope.schema.json"
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time"
    },
    "reviewedCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "reviewedBy": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "required": ["envelope", "entries"],
  "$defs": {
    "vote": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "collaborator": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "vote": {
          "type": "string",
          "enum": ["propose", "approve"]
        }
      },
      "required": ["collaborator", "vote"]
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "proposer": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "proposedAt": {
          "type": "string",
          "pattern": "^[a-z-]+ @ [a-z0-9]{7,40} \\(\\d{4}-\\d{2}-\\d{2}\\)$"
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "reasoning": {
          "type": "string",
          "minLength": 1
        },
        "votes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/vote"
          }
        }
      },
      "required": ["proposer", "proposedAt", "decision", "reasoning", "votes"]
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resolvedAt": {
          "type": "string",
          "pattern": "^[a-z-]+ @ [a-z0-9]{7,40} \\(\\d{4}-\\d{2}-\\d{2}\\)$"
        },
        "closedAt": {
          "type": "string",
          "pattern": "^[a-z-]+ @ [a-z0-9]{7,40} \\(\\d{4}-\\d{2}-\\d{2}\\)$"
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "finalVotes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/vote"
          }
        },
        "changeInstructionsRef": {
          "type": "string",
          "pattern": "^\\.spec/decisions/D-\\d{3}\\.md$"
        }
      },
      "required": ["resolvedAt", "decision", "rationale", "finalVotes", "changeInstructionsRef"]
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^D-\\d{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["open", "proposed", "resolved", "fully-closed"]
        },
        "parties": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "nature": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": ["blocking", "directional", "detail"]
        },
        "foundAt": {
          "type": "string",
          "pattern": "^[a-z-]+ @ [a-z0-9]{7,40} \\(\\d{4}-\\d{2}-\\d{2}\\)$"
        },
        "proposal": {
          "$ref": "#/$defs/proposal"
        },
        "resolution": {
          "$ref": "#/$defs/resolution"
        }
      },
      "required": ["id", "title", "status", "parties"],
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "open"
              }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["nature", "priority", "foundAt"],
            "not": {
              "anyOf": [
                { "required": ["proposal"] },
                { "required": ["resolution"] }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "proposed"
              }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["nature", "priority", "foundAt", "proposal"],
            "not": {
              "required": ["resolution"]
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "resolved"
              }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["resolution"],
            "not": {
              "anyOf": [
                { "required": ["nature"] },
                { "required": ["priority"] },
                { "required": ["foundAt"] },
                { "required": ["proposal"] }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "fully-closed"
              }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["resolution"],
            "properties": {
              "resolution": {
                "type": "object",
                "required": ["closedAt"]
              }
            },
            "not": {
              "anyOf": [
                { "required": ["nature"] },
                { "required": ["priority"] },
                { "required": ["foundAt"] },
                { "required": ["proposal"] }
              ]
            }
          }
        }
      ]
    }
  }
}