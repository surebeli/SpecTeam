{
  "name": "specteam-cli",
  "version": "3.1.0",
  "description": "Thin local CLI for SpecTeam — installs prompt skills, renders divergence status, and scaffolds .spec/. All business logic runs in your AI assistant.",
  "bin": {
    "spec": "./bin/spec.js"
  },
  "files": [
    "bin/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "node scripts/prepack.js",
    "postpack": "node scripts/postpack.js",
    "test": "node --test test/ 2>/dev/null || echo 'No tests yet'"
  },
  "keywords": [
    "specteam",
    "ai",
    "collaboration",
    "git",
    "prompt",
    "claude-code",
    "codex",
    "spec-review",
    "decision-alignment"
  ],
  "author": "SpecTeam contributors",
  "license": "MIT",
  "homepage": "https://github.com/surebeli/SpecTeam#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/surebeli/SpecTeam.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/surebeli/SpecTeam/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0"
  }
}
