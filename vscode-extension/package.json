{
  "name": "specteam-vscode",
  "displayName": "SpecTeam",
  "description": "Visual dashboard for spec divergence review and decision alignment in SpecTeam.",
  "version": "3.0.1",
  "publisher": "SpecTeam",
  "repository": {
    "type": "git",
    "url": "https://github.com/surebeli/SpecTeam.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/spec-icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specteam",
          "title": "SpecTeam",
          "icon": "resources/spec-sidebar.svg"
        }
      ]
    },
    "views": {
      "specteam": [
        {
          "id": "specteam.divergences",
          "name": "Divergence Review",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "specteam.refresh",
        "title": "Refresh Divergence Status",
        "icon": "$(refresh)"
      },
      {
        "command": "specteam.align",
        "title": "Align Divergence (spec-align)",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "specteam.refresh",
          "when": "view == specteam.divergences",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "specteam.align",
          "when": "view == specteam.divergences && viewItem == resolvable",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^16.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  }
}
